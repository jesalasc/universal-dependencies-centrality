<graph edgedefault="directed"><data key="d0">13</data>
<data key="d1">Doña_Sofía, acompañada por la ministra de Cultura, Pilar_del_Castillo, fue recibida en el Palacio_de_Lorenzana, ubicado en pleno barrio medieval y que data del siglo_XVI, por el vicepresidente de la Junta_de_Extremadura, Carlos_Sánchez_Polo, y el director de la Academia, José_Miguel_Santiago_Castelo.</data>
